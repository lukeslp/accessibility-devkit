{
  "name": "@accessibility-devkit/audit",
  "version": "1.1.1",
  "description": "Auditing and testing tools for the Accessibility Devkit.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format cjs,esm --dts --sourcemap --watch",
    "test": "vitest run --environment jsdom"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "audit",
    "testing",
    "axe"
  ],
  "author": {
    "name": "Luke Steuber",
    "email": "luke@lukesteuber.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actually-useful-ai/accessibility-devkit.git",
    "directory": "packages/audit"
  },
  "bugs": {
    "url": "https://github.com/actually-useful-ai/accessibility-devkit/issues"
  },
  "homepage": "https://github.com/actually-useful-ai/accessibility-devkit/tree/master/packages/audit#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "axe-core": "^4.12.1",
    "eslint-plugin-jsx-a11y": "^6.10.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
