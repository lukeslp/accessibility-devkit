{
  "name": "@accessibility-devkit/motion",
  "version": "0.1.0",
  "description": "Utilities for seizure and vestibular safety: reduced-motion gating, safe scrolling, and flash-rate metering.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run --environment jsdom"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "reduced-motion",
    "vestibular",
    "seizure",
    "flash",
    "animation",
    "wcag"
  ],
  "author": {
    "name": "Luke Steuber",
    "email": "luke@lukesteuber.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actually-useful-ai/accessibility-devkit.git",
    "directory": "packages/motion"
  },
  "bugs": {
    "url": "https://github.com/actually-useful-ai/accessibility-devkit/issues"
  },
  "homepage": "https://github.com/actually-useful-ai/accessibility-devkit/tree/main/packages/motion#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.11.24"
  }
}
