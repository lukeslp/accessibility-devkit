{
  "name": "@accessibility-devkit/accommodations",
  "version": "1.1.1",
  "description": "Utilities for specific disability accommodations.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --sourcemap",
    "dev": "tsup src/index.ts --format cjs,esm --dts --sourcemap --watch",
    "test": "vitest run"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "accommodations",
    "color-blindness",
    "dyslexia"
  ],
  "author": {
    "name": "Luke Steuber",
    "email": "luke@lukesteuber.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actually-useful-ai/accessibility-devkit.git",
    "directory": "packages/accommodations"
  },
  "bugs": {
    "url": "https://github.com/actually-useful-ai/accessibility-devkit/issues"
  },
  "homepage": "https://github.com/actually-useful-ai/accessibility-devkit/tree/master/packages/accommodations#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@accessibility-devkit/core": "1.1.1",
    "@bjornlu/colorblind": "1.0.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
