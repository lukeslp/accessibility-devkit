{
  "name": "@accessibility-devkit/cognitive",
  "version": "0.1.0",
  "description": "Utilities for cognitive accessibility: session-timeout warnings, redundant-entry memory, accessible authentication, and undo controllers.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run --environment jsdom"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "cognitive",
    "timeout",
    "redundant-entry",
    "authentication",
    "undo",
    "wcag"
  ],
  "author": {
    "name": "Luke Steuber",
    "email": "luke@lukesteuber.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lukeslp/accessibility-devkit.git",
    "directory": "packages/cognitive"
  },
  "bugs": {
    "url": "https://github.com/lukeslp/accessibility-devkit/issues"
  },
  "homepage": "https://github.com/lukeslp/accessibility-devkit/tree/master/packages/cognitive#readme",
  "devDependencies": {
    "@types/node": "^20.11.24"
  }
}
